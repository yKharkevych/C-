<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:Manager.ExpenseManager.Pages"
             xmlns:models="clr-namespace:Manager.ExpenseManager.DTOModels.Purses;assembly=ExpenseManager.DTOModels" 
             xmlns:vm="clr-namespace:Manager.ExpenseManager.ViewModel"
             x:Class="Manager.ExpenseManager.Pages.PursesPage"
             x:DataType="vm:PursesVM"
             Title="PursesPage">

    <!-- Відображення списку гаманців користувача -->
    <CollectionView
        ItemsSource="{Binding Purses}"
        SelectionMode="Single"
        SelectedItem="{Binding SelectedPurse}"
        SelectionChangedCommand="{Binding PurseSelectedCommand}"
        Margin="20">
        
        <CollectionView.ItemsLayout>
            <LinearItemsLayout Orientation="Vertical" ItemSpacing="9" />
        </CollectionView.ItemsLayout>
        
        <CollectionView.ItemTemplate>
            <DataTemplate
                x:DataType="models:PurseListDTO">
                <Border
                    Stroke="MidnightBlue"
                    Padding="13"
                    HorizontalOptions="Fill">
                    <VerticalStackLayout>
                        <Label 
                            FontSize="20"
                            FontAttributes="Bold"
                            TextColor="Black">
                            <MultiBinding
                                StringFormat="{}{0} ({1})">
                                <Binding Path="Name"/>
                                <Binding Path="Currency"/>
                            </MultiBinding>
                        </Label>
                        <Label 
                            Text="{Binding Balance}"/>
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>