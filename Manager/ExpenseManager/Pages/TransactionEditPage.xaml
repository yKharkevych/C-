<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Manager.ExpenseManager.ViewModel"
             x:Class="Manager.ExpenseManager.Pages.TransactionEditPage"
             x:DataType="vm:TransactionEditVM"
             Title="Edit Transaction">

    <Grid IsEnabled="{Binding IsNotBusy}">
        <ScrollView>
            <VerticalStackLayout 
                Padding="30,20" 
                Spacing="15">

                <Label 
                    Text="Amount" 
                    FontSize="18" 
                    FontAttributes="Bold" 
                    TextColor="Black" />
                <Entry 
                    Text="{Binding Amount, Mode=TwoWay}"
                    Keyboard="Numeric" />

                <Label 
                    Text="Category" 
                    FontSize="18" 
                    FontAttributes="Bold" 
                    TextColor="Black" />
                <Picker 
                    ItemsSource="{Binding Categories}"
                    SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                    ItemDisplayBinding="{Binding DisplayName}" />

                <Label 
                    Text="Date" 
                    FontSize="18" 
                    FontAttributes="Bold" 
                    TextColor="Black" />
                <DatePicker Date="{Binding Date, Mode=TwoWay}" />

                <Label 
                    Text="Description" 
                    FontSize="18" 
                    FontAttributes="Bold" 
                    TextColor="Black" />
                <Entry Text="{Binding Description, Mode=TwoWay}" />

                <Grid 
                    ColumnDefinitions="*,*" 
                    ColumnSpacing="15" 
                    Padding="0,20,0,0">
                    <Button 
                        Grid.Column="0"
                        Text="Save"
                        BackgroundColor="MidnightBlue"
                        TextColor="White"
                        Command="{Binding SaveCommand}" />
                    <Button 
                        Grid.Column="1"
                        Text="Cancel"
                        BackgroundColor="Gray"
                        TextColor="White"
                        Command="{Binding CancelCommand}" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator 
            IsVisible="{Binding IsBusy}"
            IsRunning="{Binding IsBusy}"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            Color="MidnightBlue" />
    </Grid>
</ContentPage>
