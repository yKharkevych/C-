<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:Manager.ExpenseManager.Pages"
             xmlns:models="clr-namespace:Manager.ExpenseManager.DBModels.Transactions;assembly=ExpenseManager.DTOModels" 
             xmlns:vm="clr-namespace:Manager.ExpenseManager.ViewModel"
             x:Class="Manager.ExpenseManager.Pages.PurseDetailsPage"
             x:DataType="vm:PurseDetailsVM"
             Title="Purse Details">
    <Grid
        RowDefinitions="Auto, *">
        <!-- Заголовок, що складається з назви гаманця, валюти та балансу -->
        <VerticalStackLayout
            Padding="20">
            <Label 
                 FontSize="20"
                 FontAttributes="Bold"
                 TextColor="Black">
                <MultiBinding
                     StringFormat="{}{0} ({1})">
                    <Binding Path="CurrentPurse.Name"/>
                    <Binding Path="CurrentPurse.Currency"/>
                </MultiBinding>
            </Label>
            <Label 
                 Text="{Binding CurrentPurse.Balance}"/>
        </VerticalStackLayout>

        <!-- Колекція транзакцій, що відображає список транзакцій для цього гаманця -->
        <CollectionView
            ItemsSource="{Binding Transactions}"
            SelectionMode="None"
            Margin="20,10"
            Grid.Row="1">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="7" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate
                x:DataType="models:TransactionListDTO">
                    <Grid Padding="0, 5">
                        <Border
                            Stroke="MidnightBlue"
                            Padding="13"
                            HorizontalOptions="Fill">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PurseDetailsVM}}, Path=LoadTransactionCommand}"
                                    CommandParameter="{Binding Id}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout>
                                <Label 
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="Black"
                                    Text="{Binding AmountDesc}">
                                </Label>
                                <Label Text="{Binding Category}"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>